{
  "name": "healthcare-backend",
  "version": "1.0.0",
  "description": "Backend API for Healthcare Patient Dashboard",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "test:integration": "jest --testPathPattern=integration",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "test:api": "jest --testPathPattern=providerDirectory.test.js",
    "db:migrate": "psql $DATABASE_URL -f database/provider_schema.sql && psql $DATABASE_URL -f database/additional_tables.sql",
    "db:seed": "node scripts/seedDatabase.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "dotenv": "^16.3.1",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "express-rate-limit": "^6.10.0",
    "express-validator": "^7.0.1",
    "socket.io": "^4.7.2",
    "sqlite3": "^5.1.6",
    "redis": "^4.6.7",
    "node-cache": "^5.1.2",
    "axios": "^1.5.0",
    "moment": "^2.29.4",
    "uuid": "^9.0.0",
    "compression": "^1.7.4",
    "morgan": "^1.10.0",

  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "jest": "^29.6.2",
    "supertest": "^6.3.3"
  },
  "keywords": [
    "healthcare",
    "api",
    "patient-dashboard",
    "medical-records"
  ],
  "author": "Healthcare Team",
  "license": "MIT"
}
