# Production Environment Configuration
# This file contains production-specific settings

# Application Settings
NODE_ENV=production
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=warn

# Server Configuration
HOST=0.0.0.0
PORT=3000
CORS_ORIGIN=https://healthcare-drips.com

# Database Configuration
DATABASE_URL=postgresql://username:password@host:5432/healthcare_drips_prod
DB_SSL=true
DB_POOL_SIZE=20
DB_CONNECTION_TIMEOUT=30000

# Authentication & Security
JWT_SECRET=your-super-secure-jwt-secret-key-256-bits-minimum
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=your-super-secure-refresh-token-secret-key-256-bits
REFRESH_TOKEN_EXPIRES_IN=30d
BCRYPT_ROUNDS=12

# Blockchain Configuration
ETHEREUM_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_PROJECT_ID
ETHEREUM_NETWORK_ID=1
ETHEREUM_PRIVATE_KEY=your-encrypted-private-key-here
CONTRACT_ADDRESS=0x1234567890123456789012345678901234567890
GAS_LIMIT=6000000
GAS_PRICE=20000000000

# File Storage Configuration
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=us-east-1
AWS_S3_BUCKET=healthcare-drips-prod-files
AWS_CLOUDFRONT_DISTRIBUTION=E1234567890ABCDEFGHI

# Email Configuration
EMAIL_SERVICE=sendgrid
EMAIL_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.xxxxxxxx
FROM_EMAIL=noreply@healthcare-drips.com
SUPPORT_EMAIL=support@healthcare-drips.com

# Payment Processing
STRIPE_SECRET_KEY=sk_live_1234567890123456789012345678901234
STRIPE_WEBHOOK_SECRET=whsec_1234567890123456789012345678901234

# Monitoring & Analytics
SENTRY_DSN=https://1234567890123456789012345678901234@sentry.io/1234567
DATADOG_API_KEY=1234567890123456789012345678901234
NEW_RELIC_LICENSE_KEY=1234567890123456789012345678901234abcd
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_SKIP_SUCCESSFUL_REQUESTS=false

# Cache Configuration
REDIS_URL=redis://username:password@host:6379/0
CACHE_TTL=3600
CACHE_MAX_SIZE=100

# Search Configuration
ELASTICSEARCH_URL=https://username:password@host:9200
ELASTICSEARCH_INDEX=healthcare_drips_prod

# External APIs
MAPBOX_TOKEN=pk.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
IPGEOLOCATION_API_KEY=1234567890123456789012345678901234

# Feature Flags
ENABLE_ANALYTICS=true
ENABLE_LOGGING=true
ENABLE_MONITORING=true
ENABLE_PERFORMANCE_TRACKING=true
ENABLE_ERROR_TRACKING=true

# Security Headers
HELMET_ENABLED=true
CSP_ENABLED=true
HSTS_ENABLED=true
X_FRAME_OPTIONS=DENY
X_CONTENT_TYPE_OPTIONS=nosniff

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=healthcare-drips-backups

# SSL Configuration
SSL_CERT_PATH=/path/to/certificate.crt
SSL_KEY_PATH=/path/to/private.key
SSL_CA_PATH=/path/to/ca_bundle.crt

# Performance Settings
COMPRESSION_ENABLED=true
COMPRESSION_LEVEL=6
STATIC_CACHE_MAX_AGE=31536000
API_CACHE_MAX_AGE=300

# Development Overrides (should be empty in production)
DEV_TOOLS_ENABLED=false
HOT_RELOAD_ENABLED=false
SOURCE_MAP_ENABLED=false
