# Staging Environment Configuration
# This file contains staging-specific settings

# Application Settings
NODE_ENV=staging
ENVIRONMENT=staging
DEBUG=true
LOG_LEVEL=info

# Server Configuration
HOST=0.0.0.0
PORT=3000
CORS_ORIGIN=https://staging.healthcare-drips.com

# Database Configuration
DATABASE_URL=postgresql://username:password@host:5432/healthcare_drips_staging
DB_SSL=true
DB_POOL_SIZE=10
DB_CONNECTION_TIMEOUT=15000

# Authentication & Security
JWT_SECRET=staging-jwt-secret-key-for-testing-only
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=staging-refresh-token-secret-for-testing-only
REFRESH_TOKEN_EXPIRES_IN=30d
BCRYPT_ROUNDS=10

# Blockchain Configuration
ETHEREUM_RPC_URL=https://goerli.infura.io/v3/YOUR_INFURA_PROJECT_ID
ETHEREUM_NETWORK_ID=5
ETHEREUM_PRIVATE_KEY=your-testnet-private-key-here
CONTRACT_ADDRESS=0x1234567890123456789012345678901234567890
GAS_LIMIT=6000000
GAS_PRICE=10000000000

# File Storage Configuration
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=us-east-1
AWS_S3_BUCKET=healthcare-drips-staging-files
AWS_CLOUDFRONT_DISTRIBUTION=E1234567890ABCDEFGHI

# Email Configuration
EMAIL_SERVICE=sendgrid
EMAIL_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.xxxxxxxx
FROM_EMAIL=noreply@staging.healthcare-drips.com
SUPPORT_EMAIL=support@staging.healthcare-drips.com

# Payment Processing
STRIPE_SECRET_KEY=sk_test_1234567890123456789012345678901234
STRIPE_WEBHOOK_SECRET=whsec_1234567890123456789012345678901234

# Monitoring & Analytics
SENTRY_DSN=https://1234567890123456789012345678901234@sentry.io/1234567
DATADOG_API_KEY=1234567890123456789012345678901234
NEW_RELIC_LICENSE_KEY=1234567890123456789012345678901234abcd
GOOGLE_ANALYTICS_ID=GA_MEASUREMENT_ID

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200
RATE_LIMIT_SKIP_SUCCESSFUL_REQUESTS=false

# Cache Configuration
REDIS_URL=redis://username:password@host:6379/1
CACHE_TTL=1800
CACHE_MAX_SIZE=50

# Search Configuration
ELASTICSEARCH_URL=https://username:password@host:9200
ELASTICSEARCH_INDEX=healthcare_drips_staging

# External APIs
MAPBOX_TOKEN=pk.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
IPGEOLOCATION_API_KEY=1234567890123456789012345678901234

# Feature Flags
ENABLE_ANALYTICS=true
ENABLE_LOGGING=true
ENABLE_MONITORING=true
ENABLE_PERFORMANCE_TRACKING=true
ENABLE_ERROR_TRACKING=true

# Security Headers
HELMET_ENABLED=true
CSP_ENABLED=true
HSTS_ENABLED=true
X_FRAME_OPTIONS=DENY
X_CONTENT_TYPE_OPTIONS=nosniff

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 4 * * *
BACKUP_RETENTION_DAYS=7
BACKUP_S3_BUCKET=healthcare-drips-staging-backups

# SSL Configuration
SSL_CERT_PATH=/path/to/staging-certificate.crt
SSL_KEY_PATH=/path/to/staging-private.key
SSL_CA_PATH=/path/to/staging-ca_bundle.crt

# Performance Settings
COMPRESSION_ENABLED=true
COMPRESSION_LEVEL=6
STATIC_CACHE_MAX_AGE=3600
API_CACHE_MAX_AGE=300

# Development Overrides
DEV_TOOLS_ENABLED=true
HOT_RELOAD_ENABLED=false
SOURCE_MAP_ENABLED=true
